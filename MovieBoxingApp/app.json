{
  "expo": {
    "name": "MovieBoxing",
    "description": "Your premeire fantasy movie league",
    "slug": "movieboxing",
    "backgroundColor": "#020617",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/Icon-iOS-Default-1024x1024@1x.png",
    "scheme": "movieboxingapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "jsEngine": "hermes",
    "ios": {
      "supportsTablet": true,
      "jsEngine": "hermes",
      "bundleIdentifier": "com.grantmoore.movieboxing",
      "associatedDomains": [
        "applinks:movieboxing.com"
      ]
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/icon-full.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "jsEngine": "hermes",
      "package": "com.grantmoore.movieboxing"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "jsEngine": "hermes"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/Icon-iOS-Default-1024x1024@1x.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#020618",
          "dark": {
            "backgroundColor": "#020618"
          }
        }
      ],
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.1036192699896-3orvss0jdjti8occh5ktjnffev0fkm68"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/Icon-iOS-Default-1024x1024@1x.png",
          "color": "#E6F4FE",
          "sounds": [
            "./assets/sounds/draft_alarm.wav"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "50892cbd-a5c3-4d85-8537-d4b0e6016059"
      }
    },
    "owner": "movieboxing"
  }
}
